# Copy to .env and fill in. .env is git-ignored (never commit real secrets).

# Secret that unlocks engineer-only debug endpoints (e.g. GET /debug/chunks).
# Leave unset to disable those endpoints entirely (they respond 404).
# Send it as the "X-Debug-Key" header when calling debug endpoints.
DEBUG_API_KEY=change-me-to-a-long-random-string

# Secret that unlocks the admin ingestion endpoint (POST /admin/ingest), used to
# load documents into the shared knowledge base. End users never call this.
# Leave unset to disable it (404). Send it as the "X-Admin-Key" header.
ADMIN_API_KEY=change-me-to-a-long-random-string

# Postgres connection. When unset, the app uses the in-memory vector store
# (data does not survive restarts). Matches the docker-compose.yml service.
DATABASE_URL=postgresql://rag:ragpass@localhost:5432/ragproject
